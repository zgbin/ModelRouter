<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/background"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_group_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_group_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Switch
                    android:id="@+id/switch_group_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="启用"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginEnd="8dp" />

                <ImageButton
                    android:id="@+id/btn_rename_group"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="重命名分组"
                    android:layout_marginEnd="4dp" />

                <ImageButton
                    android:id="@+id/btn_delete_group"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="删除分组"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/error" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_model"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="添加模型"
                    android:textSize="12sp"
                    app:backgroundTint="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_models"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>