<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择厂家"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_provider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surfaceVariant"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择模型"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surfaceVariant"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_or_manual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="或手动输入："
        android:textColor="@color/textMuted"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模型ID"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_model_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如: qwen/qwen3-next-80b-a3b-instruct"
        android:textSize="14sp"
        android:background="@color/surfaceVariant"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模型名称"
        android:textColor="@color/textPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_model_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如: Qwen3 Next 80B"
        android:textSize="14sp"
        android:background="@color/surfaceVariant"
        android:padding="12dp" />
</LinearLayout>
