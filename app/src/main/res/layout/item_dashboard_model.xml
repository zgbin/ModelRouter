<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@color/surface"
    android:layout_marginBottom="1dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_model_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_provider_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/chipBackground"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/info"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_model_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_marginEnd="4dp"
                android:id="@+id/iv_status"
                android:layout_width="12dp"
                android:layout_height="12dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textSecondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_tag_current"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用中"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="@drawable/badge_current"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_tag_locked"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已锁定"
            android:textColor="@color/warning"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:background="@drawable/badge_locked"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_response_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:paddingTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calls"
            android:textColor="@color/textMuted"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_requests"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_speed_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="测速"
            android:textSize="11sp"
            android:minWidth="56dp"
            android:layout_marginEnd="4dp"
            app:backgroundTint="@color/accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lock_model"
            android:textSize="11sp"
            android:minWidth="56dp"
            app:backgroundTint="@color/primary" />
    </LinearLayout>
</LinearLayout>
